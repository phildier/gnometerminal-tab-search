#!/bin/bash
# Find a python3 with the gi (GObject introspection) module and exec the switcher.
# This handles systems where python3-gi is installed for a specific version
# (e.g. system python3.12) while a version manager (asdf/pyenv) shadows python3.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Check PATH-based pythons first, then fall back to /usr/bin directly.
# The /usr/bin fallback handles systems where a version manager (asdf/pyenv)
# shadows python3 with shims that lack system packages like python3-gi.
for py in \
    python3 python3.13 python3.12 python3.11 python3.10 python3.9 \
    /usr/bin/python3 /usr/bin/python3.13 /usr/bin/python3.12 \
    /usr/bin/python3.11 /usr/bin/python3.10 /usr/bin/python3.9; do
    if command -v "$py" >/dev/null 2>&1 && "$py" -c "import gi" 2>/dev/null; then
        exec "$py" "$SCRIPT_DIR/tab-search.py"
    fi
done

echo "tab-search: no Python 3 with python3-gi found." >&2
echo "Fix: sudo apt install python3-gi gir1.2-atspi-2.0" >&2
exit 1
